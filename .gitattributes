# -----------------------------
# Macros
# -----------------------------
[attr]lfs               filter=lfs diff=lfs merge=lfs -text
[attr]unity-json        eol=lf linguist-language=json linguist-generated
[attr]unity-yaml        merge=unityyamlmerge eol=lf linguist-language=yaml linguist-generated

# -----------------------------
# Unity source (KEEP visible)
# -----------------------------
*.cs                    text diff=csharp linguist-detectable
*.shader                text linguist-detectable
*.compute               text linguist-language=hlsl linguist-detectable
*.hlsl                  text linguist-language=hlsl linguist-detectable
*.cginc                 text
*.raytrace              text linguist-language=hlsl

# -----------------------------
# Unity JSON (HIDE from stats)
# -----------------------------
*.asmdef                unity-json
*.asmref                unity-json
*.index                 unity-json
*.inputactions          unity-json
*.shadergraph           unity-json
*.shadersubgraph        unity-json

# -----------------------------
# Unity UI Toolkit
# -----------------------------
*.tss                   text diff=css linguist-language=css linguist-generated
*.uss                   text diff=css linguist-language=css linguist-generated
*.uxml                  text linguist-language=xml linguist-generated

# -----------------------------
# Unity YAML (BIGGEST NOISE → HIDE)
# -----------------------------
*.anim                  unity-yaml
*.asset                 unity-yaml
*.brush                 unity-yaml
*.controller            unity-yaml
*.flare                 unity-yaml
*.fontsettings          unity-yaml
*.giparams              unity-yaml
*.guiskin               unity-yaml
*.lighting              unity-yaml
*.mask                  unity-yaml
*.mat                   unity-yaml
*.meta                  unity-yaml
*.mixer                 unity-yaml
*.overrideController    unity-yaml
*.playable              unity-yaml
*.prefab                unity-yaml
*.preset                unity-yaml
*.renderTexture         unity-yaml
*.scenetemplate         unity-yaml
*.shadervariants        unity-yaml
*.signal                unity-yaml
*.spriteatlas           unity-yaml
*.spriteatlasv2         unity-yaml
*.terrainlayer          unity-yaml
*.unity                 unity-yaml
*.physicMaterial        unity-yaml
*.physicsMaterial2D     unity-yaml

# -----------------------------
# Vendor / generated folders
# -----------------------------
Assets/Plugins/**           linguist-generated
Packages/**                 linguist-generated
ProjectSettings/**          linguist-generated

# -----------------------------
# Git LFS (assets only)
# -----------------------------

# 3D / Maya
*.ma                    lfs
*.mb                    lfs
*.fbx                   lfs
*.FBX                   lfs
*.obj                   lfs
*.blend                 lfs
*.max                   lfs

# Audio
*.mp3                   lfs
*.wav                   lfs
*.ogg                   lfs

# Video
*.mp4                   lfs
*.mov                   lfs

# Images
*.png                   lfs
*.jpg                   lfs
*.jpeg                  lfs
*.psd                   lfs
*.tga                   lfs

# Archives / binaries
*.zip                   lfs
*.rar                   lfs
*.dll                   lfs
*.exe                   lfs

# -----------------------------
# Exceptions
# -----------------------------
LightingData.asset      binary
